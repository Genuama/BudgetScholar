# Copy this file to .env and fill in your values
# Railway will set these automatically — you only need this file locally

NODE_ENV=production

# Database (Railway provides these when you add a MySQL plugin)
DB_HOST=your-railway-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=railway

# Session secret — make this a long random string
SESSION_SECRET=change-this-to-something-long-and-random
